# SchemeSense Backend Environment Variables
# Copy this file to .env and update values for your environment

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Bedrock AI Models
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
TITAN_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# DynamoDB Tables
DYNAMODB_TABLE_SCHEMES=schemes
DYNAMODB_TABLE_USERS=users
DYNAMODB_TABLE_CONVERSATIONS=conversations
DYNAMODB_TABLE_SUBMISSIONS=form_submissions
DYNAMODB_TABLE_EMBEDDINGS=embeddings

# S3 Storage
S3_BUCKET_DOCUMENTS=schemesense-documents

# CloudWatch Logging
CLOUDWATCH_LOG_GROUP=/aws/lambda/schemesense-api

# RAG Configuration
RAW_DATA_PATH=data/raw_schemes.json
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Vector Database (OpenSearch) - Add when implementing vector search
OPENSEARCH_ENDPOINT=search-schemesense-domain.us-east-1.es.amazonaws.com
OPENSEARCH_USER=schemesense-user
OPENSEARCH_PASS=your-opensearch-password

# Development Settings
DEBUG=true
LOG_LEVEL=INFO
