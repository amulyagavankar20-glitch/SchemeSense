# SchemeSense Backend Environment Variables
# Copy this file to `.env` inside your `backend/` directory 
# and update values for your live AWS deployment.

# ==========================================
# 1. AWS API Credentials (REQUIRED)
# ==========================================
# If running locally using `ingest_dynamo.py` or standard Python scripts,
# these keys must be provided. If the code is running *inside* an AWS Lambda
# with an IAM Role, these can be left blank/omitted.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# If using AWS temporary credentials (e.g. from AWS SSO or STS), add this line:
# AWS_SESSION_TOKEN=your-aws-session-token

# ==========================================
# 2. Google Gemini AI Models (REQUIRED)
# ==========================================
# We use Gemini as a highly scalable fallback to bypass AWS throttling.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_ID=gemini-2.5-flash

# ==========================================
# 3. DynamoDB Tables (OPTIONAL/DEFAULTS)
# ==========================================
# These match the names generated by your Terraform scripts.
# You only need to change these if you customized the table names in Terraform.
DYNAMODB_TABLE_SCHEMES=schemes
DYNAMODB_TABLE_USERS=users
DYNAMODB_TABLE_CONVERSATIONS=conversations
DYNAMODB_TABLE_SUBMISSIONS=form_submissions
DYNAMODB_TABLE_EMBEDDINGS=embeddings


