# SchemeSense Frontend Environment Variables
# Copy this file to `.env` inside your `frontend/` directory
# and update the VITE_API_BASE_URL for your live AWS deployment.

# ==========================================
# 1. API Gateway URL (REQUIRED)
# ==========================================
# After running `terraform apply`, AWS will output an API Gateway URL.
# Replace the placeholder below with that actual URL.
# Ensure you do NOT include a trailing slash (e.g., https://xyz.execute-api.us-east-1.amazonaws.com)

VITE_API_BASE_URL=https://your-api-gateway-url.amazonaws.com

# (For local testing without AWS, you can temporarily use http://localhost:5000)

# ==========================================
# 2. Application Settings (OPTIONAL)
# ==========================================
VITE_APP_ENV=production
VITE_APP_NAME=SchemeSense
